#!/usr/bin/env bash
# Pre-commit hook: format check, clippy, and normalize checks
#
# Install: cp scripts/pre-commit .git/hooks/pre-commit && chmod +x .git/hooks/pre-commit

set -e

echo "Running cargo fmt check..."
cargo fmt --check

echo "Running cargo clippy..."
cargo clippy --all-targets --all-features -- -D warnings 2>/dev/null || {
    echo "  Warning: clippy check failed or not available (non-critical)"
}

# Run normalize checks if binary exists.
# Prefer debug (always current); release may be stale during active development.
if [ -x "./target/debug/normalize" ] || [ -x "./target/release/normalize" ]; then
    NORMALIZE="${NORMALIZE:-./target/debug/normalize}"
    [ -x "$NORMALIZE" ] || NORMALIZE="./target/release/normalize"

    if [ -x "$NORMALIZE" ]; then
        # Run syntax + native engines (SUMMARY.md staleness, broken refs, etc.).
        # severity=error issues block commits; warnings are informational.
        # Use `normalize rules run --limit 0` to see full list.
        # NOTE: --type fact is skipped here due to a known malloc crash in the fact
        # engine (heap corruption in ascent-interpreter / abi_stable dylib boundary).
        # Tracked as a 0.3.0 bug; re-enable once fixed.
        echo "Running normalize rules (syntax + native)..."
        $NORMALIZE rules run --type syntax
        $NORMALIZE rules run --type native
    fi
fi

echo "Pre-commit checks passed!"
