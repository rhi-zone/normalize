#!/usr/bin/env bash
# Pre-commit hook: format check, clippy, and normalize checks
#
# Install: cp scripts/pre-commit .git/hooks/pre-commit && chmod +x .git/hooks/pre-commit

set -e

echo "Running cargo fmt check..."
cargo fmt --check

echo "Running cargo clippy..."
cargo clippy --all-targets --all-features -- -D warnings 2>/dev/null || {
    echo "  Warning: clippy check failed or not available (non-critical)"
}

# Run normalize checks if binary exists.
# Prefer debug (always current); release may be stale during active development.
if [ -x "./target/debug/normalize" ] || [ -x "./target/release/normalize" ]; then
    NORMALIZE="${NORMALIZE:-./target/debug/normalize}"
    [ -x "$NORMALIZE" ] || NORMALIZE="./target/release/normalize"

    if [ -x "$NORMALIZE" ]; then
        # Run all enabled rules (informational until existing violations are fixed — see TODO.md).
        # Remove --no-fail once error-severity violations are resolved.
        # Use `normalize rules run --limit 0` for full list.
        echo "Running normalize rules..."
        $NORMALIZE rules run --engine syntax --no-fail

        # Check SUMMARY.md freshness (currently info severity — see TODO.md §Bootstrap SUMMARY.md).
        # Once severity=error is re-enabled in .normalize/config.toml, this will block on errors.
        echo "Running SUMMARY.md freshness check..."
        $NORMALIZE analyze check --summary
    fi
fi

echo "Pre-commit checks passed!"
