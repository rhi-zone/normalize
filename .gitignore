# Nix build output symlink
/result

# Documentation build
site/
docs/.vitepress/dist/
docs/.vitepress/cache/

# Normalize runtime data (see bottom for exceptions)

# Python
__pycache__/
*.py[cod]
*$py.class
*.so
.Python
.venv/
venv/
*.egg-info/
*.egg
.mypy_cache/
.ruff_cache/
.pytest_cache/
.coverage
coverage.xml
htmlcov/

# build output
dist/
target/
# generated types
.astro/

# dependencies
node_modules/
bun.lockb

# logs
npm-debug.log*
yarn-debug.log*
yarn-error.log*
pnpm-debug.log*


# environment variables
.env
.env.production

# macOS-specific files
.DS_Store

# Desloppify
.desloppify/
scorecard.png

# jetbrains setting folder
.idea/

# direnv
.direnv/

# database
*.sqlite
*.sqlite-shm
*.sqlite-wal

# typescript build info
*.tsbuildinfo

# vitepress cache
cache/

# debugging text files
*.txt
# ...except fixture expected outputs
!**/tests/fixtures/**/expected/*.txt
# ...except embedded help text included via include_str!
!**/src/**/help.txt

*.cpuprofile

# Normalize - ignore .normalize/ in subdirectories (but not root)
*/**/.normalize/

# Root .normalize/ - ignore all but config files
/.normalize/*
!/.normalize/config.toml
!/.normalize/SUMMARY.md
!/.normalize/rule-tests/
!/.normalize/kg/

# Normalize
.normalize/*
!.normalize/config.toml
!.normalize/SUMMARY.md
!.normalize/rule-tests/
!.normalize/memory/
!.normalize/kg/
.normalize/shadow
.fastembed_cache/
